{
  "name": "tradeaxis-api",
  "version": "1.0.0",
  "description": "Miziba Infrastructure Ltd — TradeAxis Trade Finance Origination API",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start":         "node src/server.js",
    "dev":           "nodemon src/server.js",
    "test":          "jest --runInBand",
    "test:watch":    "jest --watch",
    "test:coverage": "jest --coverage",
    "lint":          "eslint src/ core/",
    "lint:fix":      "eslint src/ core/ --fix",
    "db:migrate":    "node-pg-migrate up",
    "db:rollback":   "node-pg-migrate down",
    "db:seed":       "node src/db/seed.js"
  },
  "dependencies": {
    "express":             "^4.18.2",
    "express-validator":   "^7.0.1",
    "jsonwebtoken":        "^9.0.2",
    "bcryptjs":            "^2.4.3",
    "otplib":              "^12.0.1",
    "pg":                  "^8.11.3",
    "redis":               "^4.6.11",
    "aws-sdk":             "^2.1502.0",
    "@aws-sdk/client-s3":  "^3.450.0",
    "@aws-sdk/s3-request-presigner": "^3.450.0",
    "@aws-sdk/client-sqs": "^3.450.0",
    "@aws-sdk/client-ses": "^3.450.0",
    "@aws-sdk/client-secretsmanager": "^3.450.0",
    "axios":               "^1.6.2",
    "cors":                "^2.8.5",
    "helmet":              "^7.1.0",
    "express-rate-limit":  "^7.1.5",
    "uuid":                "^9.0.0",
    "joi":                 "^17.11.0",
    "pino":                "^8.17.2",
    "pino-http":           "^9.0.0",
    "dotenv":              "^16.3.1"
  },
  "devDependencies": {
    "nodemon":             "^3.0.2",
    "jest":                "^29.7.0",
    "supertest":           "^6.3.3",
    "eslint":              "^8.55.0",
    "node-pg-migrate":     "^6.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": ["src/**/*.js", "core/**/*.js"],
    "coverageThreshold": {
      "global": {
        "branches":   70,
        "functions":  80,
        "lines":      80,
        "statements": 80
      }
    }
  }
}
